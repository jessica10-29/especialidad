# Seguridad y forzado de HTTPS (puede forzar tambiÃ©n en localhost)
RewriteEngine On

# Bloquear acceso directo a archivos/carpetas ocultos, excepto ACME/.well-known
RewriteRule "(^|/)\.(?!well-known(?:/|$))" - [F,L,NC]

# Bloquear carpetas internas que nunca deben servirse públicamente
RewriteRule "^(logs|secure|\.git|\.github|\.vscode)(?:/|$)" - [F,L,NC]

# Marcar entorno local para cabeceras condicionales
SetEnvIf Host "^(localhost|127\\.0\\.0\\.1)(:\\d+)?$" IS_LOCAL=1

# Opcional: forzar HTTPS tambiÃ©n en localhost si hay cert instalado
# Activa poniendo FORZAR_HTTPS=1 en Apache o descomenta la siguiente lÃ­nea
# SetEnv FORZAR_HTTPS 1

# Redirigir a HTTPS (respeta proxys tipo Cloudflare)
RewriteCond %{ENV:FORZAR_HTTPS} =1 [OR]
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Cabeceras de seguridad básicas
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on' && %{ENV:IS_LOCAL} != '1'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # CSP estricta en producción, más permisiva en localhost (sin upgrade a HTTPS)
  Header always set Content-Security-Policy "default-src 'self' data:; img-src 'self' data: https://api.qrserver.com https://chart.googleapis.com https://bwipjs-api.metafloor.com https://ui-avatars.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' data: https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests; block-all-mixed-content;" "expr=%{ENV:IS_LOCAL} != '1'"
  Header always set Content-Security-Policy "default-src 'self' data:; img-src 'self' data: http: https: https://api.qrserver.com https://chart.googleapis.com https://bwipjs-api.metafloor.com https://ui-avatars.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; font-src 'self' data: https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self' http: https:; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none';" "expr=%{ENV:IS_LOCAL} == '1'"
</IfModule>

# Evitar exposición de archivos sensibles / de prueba
Options -Indexes
<FilesMatch "(?i)^(test_|debug_|probador_completo|temp_diag|fix_db|doctor_|actualizar_|finalizar_actualizacion_).+\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "(?i)^(DIAGNOSTICO_CORREOS|PRUEBA_COLA_CORREOS|enviar_test_smtp|verificar_chrome|admin_cola_correos|forzar_envio_correos)\.(php|html)$">
  Require all denied
</FilesMatch>
<Files "CONTROL_CORREOS.html">
  Require all denied
</Files>
<FilesMatch "(?i)\.(sql|zip|rar|7z|bak|md|log|ini|env|ya?ml|dist|ps1|bat|cmd)$">
  Require all denied
</FilesMatch>
